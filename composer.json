{
    "name": "detain/phlix-plugin-anidb",
    "type": "phlix-plugin",
    "description": "AniDB metadata provider — anime titles, descriptions, episodes, ratings via UDP API and title dump.",
    "license": "MIT",
    "keywords": ["phlix", "phlix-plugin", "metadata-provider", "anidb", "anime"],
    "homepage": "https://github.com/detain/phlix-plugin-anidb",
    "require": {
        "php": ">=8.3",
        "detain/phlix-shared": "^0.12.0",
        "psr/container": "^1.1 || ^2.0",
        "psr/log": "^1.0 || ^2.0 || ^3.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^10.0"
    },
    "repositories": [
        { "type": "vcs", "url": "https://github.com/detain/phlix-shared.git" }
    ],
    "autoload": {
        "psr-4": {
            "Phlix\\Anidb\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phlix\\Anidb\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
